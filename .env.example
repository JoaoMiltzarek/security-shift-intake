# Copy to .env (gitignored) and fill in to run the REAL VLM via `make demo-transcribe`.
# Tests and CI use the mock client and need none of these.

# Anthropic API key — required only for real model calls.
ANTHROPIC_API_KEY=

# Optional overrides (defaults live in src/clients/settings.py).
# VISION_MODEL=claude-opus-4-8
# VISION_MAX_TOKENS=4096

# --- Reader selection (no API, fully local). Tests/CI need none of these. ---
# Which VisionClient the demo/CLI uses: local_ocr (default), local_vlm, mock, anthropic.
# INTAKE_VISION=local_vlm

# Local open VLM (OpenAI-compatible server: Ollama / vLLM / LM Studio / llama.cpp).
# Nothing leaves the machine; no paid API. Defaults in src/clients/settings.py.
# INTAKE_VLM_BASE_URL=http://localhost:11434/v1
# INTAKE_VLM_MODEL=qwen2.5vl:3b          # fits ~4 GB VRAM (e.g. GTX 1050 Ti)
# INTAKE_VLM_API_KEY=not-needed-for-local
# INTAKE_VLM_TIMEOUT_S=600
# INTAKE_VLM_CONFIDENCE=0.5              # fallback when the server returns no logprobs

# Real-handwriting eval dataset (see docs/EVAL_BRESSAY.md). Not vendored.
# BRESSAY_DIR=data/bressay
