# Copy to .env (gitignored) and fill in to run the REAL VLM via `make demo-transcribe`.
# Tests and CI use the mock client and need none of these.

# Anthropic API key — required only for real model calls.
ANTHROPIC_API_KEY=

# Optional overrides (defaults live in src/clients/settings.py).
# VISION_MODEL=claude-opus-4-8
# VISION_MAX_TOKENS=4096
